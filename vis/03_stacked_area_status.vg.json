{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "data": {
    "url": "data/chart3_visa_groups_stacked_area.csv",
    "format": {
      "type": "csv"
    }
  },
  "transform": [
    {
      "fold": [
        "permanent_visas",
        "temporary_visas",
        "nz_citizens",
        "aus_citizens"
      ],
      "as": [
        "visa_type",
        "count"
      ]
    },
    {
      "calculate": "toNumber(datum.count)",
      "as": "count"
    },
    {
      "calculate": "datum.visa_type == 'permanent_visas' ? 'Permanent Visas' : datum.visa_type == 'temporary_visas' ? 'Temporary Visas' : datum.visa_type == 'nz_citizens' ? 'NZ Citizens' : 'Australian Citizens'",
      "as": "visa_label"
    }
  ],
  "vconcat": [
    {
      "width": "container",
      "height": 280,
      "mark": {
        "type": "area",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "scale": {
            "domain": {
              "param": "brush"
            },
            "padding": 0
          },
          "axis": {
            "labelAngle": -45,
            "labelFontSize": 11
          }
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "title": "Number of People",
          "stack": "zero",
          "axis": {
            "format": ","
          }
        },
        "color": {
          "field": "visa_label",
          "type": "nominal",
          "title": "Traveller Type",
          "scale": {
            "domain": [
              "Permanent Visas",
              "Temporary Visas",
              "NZ Citizens",
              "Australian Citizens"
            ],
            "range": [
              "#245f73",
              "#4a9ab5",
              "#82c4d4",
              "#c8e8f0"
            ]
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "visa_label",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "count",
            "type": "quantitative",
            "title": "Count",
            "format": ","
          }
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "area",
            "opacity": 0.85
          },
          "encoding": {
            "x": {
              "field": "year",
              "type": "ordinal",
              "title": null,
              "scale": {
                "domain": {
                  "param": "brush"
                },
                "padding": 0
              },
              "axis": {
                "labelAngle": -45,
                "labelFontSize": 11
              }
            },
            "y": {
              "field": "count",
              "type": "quantitative",
              "title": "Number of People",
              "stack": "zero",
              "axis": {
                "format": ","
              }
            },
            "color": {
              "field": "visa_label",
              "type": "nominal",
              "title": "Traveller Type",
              "scale": {
                "domain": [
                  "Permanent Visas",
                  "Temporary Visas",
                  "NZ Citizens",
                  "Australian Citizens"
                ],
                "range": [
                  "#245f73",
                  "#4a9ab5",
                  "#82c4d4",
                  "#c8e8f0"
                ]
              }
            },
            "tooltip": [
              {
                "field": "year",
                "type": "ordinal",
                "title": "Year"
              },
              {
                "field": "visa_label",
                "type": "nominal",
                "title": "Type"
              },
              {
                "field": "count",
                "type": "quantitative",
                "title": "Count",
                "format": ","
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {
                "year": "2005-06",
                "label": "20-yr avg: ~230k/yr \u00b7 Peak 2022\u201323: 739k total"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#245f73"
          },
          "encoding": {
            "x": {
              "field": "year",
              "type": "ordinal"
            },
            "y": {
              "datum": 730000,
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "values": [
              {
                "year": "2020-21",
                "label": "Borders closed \u00b7 All categories collapsed"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "center",
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#c0392b"
          },
          "encoding": {
            "x": {
              "field": "year",
              "type": "ordinal"
            },
            "y": {
              "datum": 730000,
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "width": "container",
      "height": 65,
      "params": [
        {
          "name": "brush",
          "select": {
            "type": "interval",
            "encodings": [
              "x"
            ]
          }
        }
      ],
      "mark": {
        "type": "area",
        "opacity": 0.6
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "scale": {
            "padding": 0
          },
          "axis": {
            "labelAngle": -45,
            "labelFontSize": 9
          }
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "stack": "zero",
          "title": null,
          "axis": null
        },
        "color": {
          "field": "visa_label",
          "type": "nominal",
          "scale": {
            "domain": [
              "Permanent Visas",
              "Temporary Visas",
              "NZ Citizens",
              "Australian Citizens"
            ],
            "range": [
              "#245f73",
              "#4a9ab5",
              "#82c4d4",
              "#c8e8f0"
            ]
          },
          "legend": null
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "concat": {
      "spacing": 8
    }
  }
}